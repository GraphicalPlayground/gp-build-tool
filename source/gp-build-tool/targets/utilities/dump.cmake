include(gp-build-tool/targets/utilities/shared)

# @brief Utility functions for dumping target properties to the log for debugging purposes.
# @param[in] groupName Name of the property group to log, e.g. "Sources", "PublicIncludeDirectories", etc.
# @param[in] list The list variable containing the properties to log.
macro(gpbt_dumpList groupName list)
  list(LENGTH "${list}" listLength)
  if(listLength GREATER 0)
    gpbt_log(DEBUG "${groupName}:")
    foreach(_item IN LISTS "${list}")
      gpbt_log(BULLET "${_item}")
    endforeach()
  else()
    gpbt_log(DEBUG "${groupName}: (none)")
  endif()
endmacro()

# @brief Dump all properties of the current target to the log for debugging purposes.
function(gpbt_dumpTargetProperties)
  gpbt_checkInTargetDefinition("gpbt_dumpTargetProperties")
  gpbt_runOnlyDuringPhase("CONFIGURATION")

  # Get all the properties of the current target and store them in local variables.
  gpbt_getAllScopedTargetProperty()

  gpbt_startGroup("Dumping of the target '${targetName}'")
  gpbt_logSection("Target: '${targetName}' properties")

  gpbt_log(DEBUG "Name: ${targetName}")
  gpbt_log(DEBUG "CleanName: ${targetCleanName}")
  gpbt_log(DEBUG "Guid: ${targetGuid}")
  gpbt_log(DEBUG "Type: ${targetType}")
  gpbt_log(DEBUG "OutputName: ${targetOutputName}")
  gpbt_log(DEBUG "ExportName: ${targetExportName}")
  gpbt_log(DEBUG "Aliases: ${targetAliases}")
  gpbt_log(DEBUG "Location: ${targetLocation}")
  gpbt_log(DEBUG "CustomFolder: ${targetCustomFolder}")
  gpbt_logNewLine()
  gpbt_dumpList("Sources" targetSources)
  gpbt_dumpList("PreCompiledHeaders" targetPreCompiledHeaders)
  gpbt_logNewLine()
  gpbt_dumpList("PublicIncludeDirectories" targetPublicIncludeDirectories)
  gpbt_dumpList("InternalIncludeDirectories" targetInternalIncludeDirectories)
  gpbt_dumpList("PrivateIncludeDirectories" targetPrivateIncludeDirectories)
  gpbt_logNewLine()
  gpbt_dumpList("PublicDependencies" targetPublicDependencies)
  gpbt_dumpList("InternalDependencies" targetInternalDependencies)
  gpbt_dumpList("PrivateDependencies" targetPrivateDependencies)
  gpbt_dumpList("DynamicDependencies" targetDynamicDependencies)
  gpbt_logNewLine()
  gpbt_dumpList("PublicCompileDefinitions" targetPublicCompileDefinitions)
  gpbt_dumpList("InternalCompileDefinitions" targetInternalCompileDefinitions)
  gpbt_dumpList("PrivateCompileDefinitions" targetPrivateCompileDefinitions)
  gpbt_logNewLine()
  gpbt_dumpList("PublicCompileOptions" targetPublicCompileOptions)
  gpbt_dumpList("InternalCompileOptions" targetInternalCompileOptions)
  gpbt_dumpList("PrivateCompileOptions" targetPrivateCompileOptions)
  gpbt_logNewLine()
  gpbt_dumpList("PublicLinkOptions" targetPublicLinkOptions)
  gpbt_dumpList("InternalLinkOptions" targetInternalLinkOptions)
  gpbt_dumpList("PrivateLinkOptions" targetPrivateLinkOptions)
  gpbt_logNewLine()
  gpbt_log(DEBUG "IsHeaderOnly: ${targetIsHeaderOnly}")
  gpbt_log(DEBUG "EnableTests: ${targetEnableTests}")
  gpbt_log(DEBUG "EnableBenchmarks: ${targetEnableBenchmarks}")
  gpbt_log(DEBUG "EnableExamples: ${targetEnableExamples}")
  gpbt_log(DEBUG "EnableISPC: ${targetEnableISPC}")
  gpbt_log(DEBUG "EnableStrictWarnings: ${targetEnableStrictWarnings}")
  gpbt_log(DEBUG "EnableUnityBuild: ${targetEnableUnityBuild}")
  gpbt_log(DEBUG "IsBuildShared: ${targetIsBuildShared}")
  if(targetType STREQUAL "executable")
    gpbt_dumpList("ExecutableResourceFiles" targetExecutableResourceFiles)
    gpbt_log(DEBUG "ExecutableEntryPoint: ${targetExecutableEntryPoint}")
    gpbt_log(DEBUG "ExecutableHasGui: ${targetExecutableHasGui}")
  endif()

  gpbt_logNewLine()
  gpbt_logSeparator()
  gpbt_logNewLine()
  gpbt_endGroup()
endfunction()
