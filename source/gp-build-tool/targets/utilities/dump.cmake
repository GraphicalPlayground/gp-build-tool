# @brief Utility functions for dumping target properties to the log for debugging purposes.
# @param[in] groupName Name of the property group to log, e.g. "Sources", "PublicIncludeDirectories", etc.
# @param[in] list The list variable containing the properties to log.
macro(gpbt_dumpList groupName list)
  if(NOT "${list}" STREQUAL "")
    gpbt_log(DEBUG "${groupName}:")
    foreach(_item IN LISTS "${list}")
      gpbt_log(BULLET "${_item}")
    endforeach()
  else()
    gpbt_log(DEBUG "${groupName}: (none)")
  endif()
endmacro()

# @brief Dump all properties of the current target to the log for debugging purposes.
function(gpbt_dumpTargetProperties)
  gpbt_getProperty(GPBT_IS_IN_TARGET_DEFINITION isInTargetDefinition)
  if(NOT isInTargetDefinition)
    gpbt_log(FATAL "gpbt_dumpTargetProperties called without a matching gpbt_startTarget")
  endif()

  gpbt_getScopedProperty(_targetName targetName)
  gpbt_getScopedProperty(_targetCleanName targetCleanName)
  gpbt_getScopedProperty(_targetGuid targetGuid)
  gpbt_getScopedProperty(_targetType targetType)
  gpbt_getScopedProperty(_targetOutputName targetOutputName)
  gpbt_getScopedProperty(_targetExportName targetExportName)
  gpbt_getScopedProperty(_targetAliases targetAliases)
  gpbt_getScopedProperty(_targetLocation targetLocation)
  gpbt_getScopedProperty(_targetCustomFolder targetCustomFolder)
  gpbt_getScopedProperty(_targetSources targetSources)
  gpbt_getScopedProperty(_targetPreCompiledHeaders targetPreCompiledHeaders)
  gpbt_getScopedProperty(_targetPublicIncludeDirectories targetPublicIncludeDirectories)
  gpbt_getScopedProperty(_targetInternalIncludeDirectories targetInternalIncludeDirectories)
  gpbt_getScopedProperty(_targetPrivateIncludeDirectories targetPrivateIncludeDirectories)
  gpbt_getScopedProperty(_targetPublicDependencies targetPublicDependencies)
  gpbt_getScopedProperty(_targetInternalDependencies targetInternalDependencies)
  gpbt_getScopedProperty(_targetPrivateDependencies targetPrivateDependencies)
  gpbt_getScopedProperty(_targetDynamicDependencies targetDynamicDependencies)
  gpbt_getScopedProperty(_targetPublicCompileDefinitions targetPublicCompileDefinitions)
  gpbt_getScopedProperty(_targetInternalCompileDefinitions targetInternalCompileDefinitions)
  gpbt_getScopedProperty(_targetPrivateCompileDefinitions targetPrivateCompileDefinitions)
  gpbt_getScopedProperty(_targetPublicCompileOptions targetPublicCompileOptions)
  gpbt_getScopedProperty(_targetInternalCompileOptions targetInternalCompileOptions)
  gpbt_getScopedProperty(_targetPrivateCompileOptions targetPrivateCompileOptions)
  gpbt_getScopedProperty(_targetIsHeaderOnly targetIsHeaderOnly)
  gpbt_getScopedProperty(_targetEnableTests targetEnableTests)
  gpbt_getScopedProperty(_targetEnableBenchmarks targetEnableBenchmarks)
  gpbt_getScopedProperty(_targetEnableExamples targetEnableExamples)
  gpbt_getScopedProperty(_targetEnableISPC targetEnableISPC)
  gpbt_getScopedProperty(_targetEnableStrictWarnings targetEnableStrictWarnings)
  gpbt_getScopedProperty(_targetEnableUnityBuild targetEnableUnityBuild)

  gpbt_startGroup("Dumping of the target '${targetName}'")
  gpbt_logSection("Target: '${targetName}' properties")

  gpbt_log(DEBUG "Name: ${targetName}")
  gpbt_log(DEBUG "CleanName: ${targetCleanName}")
  gpbt_log(DEBUG "Guid: ${targetGuid}")
  gpbt_log(DEBUG "Type: ${targetType}")
  gpbt_log(DEBUG "OutputName: ${targetOutputName}")
  gpbt_log(DEBUG "ExportName: ${targetExportName}")
  gpbt_log(DEBUG "Aliases: ${targetAliases}")
  gpbt_log(DEBUG "Location: ${targetLocation}")
  gpbt_log(DEBUG "CustomFolder: ${targetCustomFolder}")
  gpbt_logNewLine()
  gpbt_dumpList("Sources" targetSources)
  gpbt_dumpList("PreCompiledHeaders" targetPreCompiledHeaders)
  gpbt_logNewLine()
  gpbt_dumpList("PublicIncludeDirectories" targetPublicIncludeDirectories)
  gpbt_dumpList("InternalIncludeDirectories" targetInternalIncludeDirectories)
  gpbt_dumpList("PrivateIncludeDirectories" targetPrivateIncludeDirectories)
  gpbt_logNewLine()
  gpbt_dumpList("PublicDependencies" targetPublicDependencies)
  gpbt_dumpList("InternalDependencies" targetInternalDependencies)
  gpbt_dumpList("PrivateDependencies" targetPrivateDependencies)
  gpbt_dumpList("DynamicDependencies" targetDynamicDependencies)
  gpbt_logNewLine()
  gpbt_dumpList("PublicCompileDefinitions" targetPublicCompileDefinitions)
  gpbt_dumpList("InternalCompileDefinitions" targetInternalCompileDefinitions)
  gpbt_dumpList("PrivateCompileDefinitions" targetPrivateCompileDefinitions)
  gpbt_logNewLine()
  gpbt_dumpList("PublicCompileOptions" targetPublicCompileOptions)
  gpbt_dumpList("InternalCompileOptions" targetInternalCompileOptions)
  gpbt_dumpList("PrivateCompileOptions" targetPrivateCompileOptions)
  gpbt_logNewLine()
  gpbt_log(DEBUG "IsHeaderOnly: ${targetIsHeaderOnly}")
  gpbt_log(DEBUG "EnableTests: ${targetEnableTests}")
  gpbt_log(DEBUG "EnableBenchmarks: ${targetEnableBenchmarks}")
  gpbt_log(DEBUG "EnableExamples: ${targetEnableExamples}")
  gpbt_log(DEBUG "EnableISPC: ${targetEnableISPC}")
  gpbt_log(DEBUG "EnableStrictWarnings: ${targetEnableStrictWarnings}")
  gpbt_log(DEBUG "EnableUnityBuild: ${targetEnableUnityBuild}")

  gpbt_logNewLine()
  gpbt_logSeparator()
  gpbt_logNewLine()
  gpbt_endGroup()
endfunction()
